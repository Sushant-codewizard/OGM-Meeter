{
  "version": 2,
  "builds": [
    {
      "src": "meeting-bot/backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/docs",
      "dest": "meeting-bot/backend/main.py"
    },
    {
      "src": "/openapi.json",
      "dest": "meeting-bot/backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "meeting-bot/backend/main.py"
    }
  ]
}
